# Copy this file to .env and adjust as needed.

# --- App ---
APP_NAME=DocMind Chat
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# --- Storage paths (inside the container) ---
DATA_DIR=/app/data
USER_DOCS_DIR=/app/data/user_docs
CHROMA_DIR=/app/data/chroma_db
CHROMA_COLLECTION_NAME=docmind_collection

# --- Embedding model (HuggingFace, downloaded on first run & cached) ---
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- LLM model (HuggingFace, downloaded on first run & cached) ---
LLM_MODEL_NAME=microsoft/phi-2
LLM_CONTEXT_WINDOW=2048
LLM_MAX_NEW_TOKENS=256
# "auto" uses GPU if available (via accelerate), "cpu" forces CPU
LLM_DEVICE_MAP=auto

# --- Retrieval defaults ---
SIMILARITY_TOP_K=4
RESPONSE_MODE=compact

# --- HuggingFace cache location (persisted via volume so models aren't
#     re-downloaded on every container restart) ---
HF_HOME=/app/data/hf_cache
